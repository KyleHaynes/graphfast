# R specific
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# Package building
/src/*.o
/src/*.so
/src/*.dll
# NOTE: man/*.Rd, R/RcppExports.R and src/RcppExports.cpp are GENERATED but MUST
# be committed, otherwise CI / install_github builds a package with no Rd docs and
# no Rcpp wrappers (R CMD check then fails). Do not re-add them to this ignore list.

# Build artifacts
*.tar.gz
/check/
/build/

# Quarto documentation site
/site/
/.quarto/
/_freeze/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temporary files
*~
*.tmp
*.temp

# Large test files (optional - remove if you want to commit test data)
*_test_large*
*_performance_large*

# Private/local configuration
.env
config_local.*
/Meta/

**/*.quarto_ipynb
